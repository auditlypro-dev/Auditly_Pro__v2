# ==========================================
# Auditly Pro v2 Environment Variables
# ==========================================

# Shopify App Credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Shopify API Permissions
SHOPIFY_SCOPES=read_content,write_content,read_products,write_products,read_themes,write_themes

# Application URL
HOST=https://your-render-url.onrender.com

# Server Port
PORT=10000
